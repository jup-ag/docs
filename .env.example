# Environment for the `document-from-source` skill.
# Copy to `.env` (gitignored) and fill in. Never commit real values.
# Any of these can also be passed as invocation args (args override env).

# Solana mainnet RPC endpoint.
RPC_URL=

# API key for api.jup.ag hosts that require one. Some read endpoints work keyless
# (e.g. lite-api.jup.ag) — leave blank if you only hit keyless hosts.
JUPITER_API_KEY=

# Dedicated LOW-FUND TEST WALLET — never a real user wallet. Set ONE of:
#   BS58_PRIVATE_KEY — base58 secret (how browser wallets export), OR
#   KEYPAIR_PATH     — path to a keypair JSON array file.
BS58_PRIVATE_KEY=
# KEYPAIR_PATH=/absolute/path/to/test-wallet.json

# Absolute path to your workbench OUTSIDE this repo, where trace scripts run and
# Solana SDK deps are installed. Runtime (Bun/Node) and SDK (kit/web3.js) are
# inferred from this directory.
WORKBENCH_DIR=
